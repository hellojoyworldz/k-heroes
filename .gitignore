# =========================================================================
# FRONTEND (Next.js / Node.js)
# =========================================================================

# Dependencies (라이브러리 및 패키지)
/frontend/node_modules/
/frontend/.pnp
.pnp.*
/frontend/.yarn/*
!/frontend/.yarn/patches
!/frontend/.yarn/plugins
!/frontend/.yarn/releases
!/frontend/.yarn/versions

# Next.js 빌드 및 산출물
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/*.tsbuildinfo
/frontend/next-env.d.ts

# Testing (테스트 결과 리포트)
/frontend/coverage/

# Debug Logs (디버그 로그)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel 배포 관련 임시 파일
/frontend/.vercel/


# =========================================================================
# BACKEND (FastAPI / Python)
# =========================================================================

# Virtual Environment (파이썬 가상환경)
**/venv/
**/.venv/
venv/
.venv/

# Python Cache (컴파일 임시 파일)
**/__pycache__/
**/*.pyc
__pycache__/
*.pyc

# Local Database (로컬 테스트용 SQLite 등 임시 DB)
*.db
*.sqlite3


# =========================================================================
# DATA SCIENCE & NOTEBOOKS (주피터 노트북 및 데이터 전처리 필수 항목)
# =========================================================================

# Jupyter Notebook 임시 체크포인트 (자동 저장용 숨김 폴더)
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# 주피터 노트북 실행 중 생성되는 자동 저장 임시 파일
*/.ipynb_checkpoints/*

# 대용량 데이터 파일 (GitHub 업로드 용량 제한 100MB 방지 및 보안)
# **/data/raw/
# **/data/proceed/
# *.csv
# *.json
# *.xlsx

# (옵션) 만약 git에 데이터 파일 구조용 빈 폴더만 남기고 싶다면 아래 주석을 해제.
# !**/data/raw/.gitkeep
# !**/data/proceed/.gitkeep


# =========================================================================
# COMMON & SECURITY (공통 및 보안 필수 항목)
# =========================================================================

# OS Generated Files (운영체제 임시 파일)
.DS_Store
Thumbs.db

# SSL/TLS Certificates (인증서 키 파일)
*.pem
*.key

# Environment Variables (환경 변수 파일)
.env
.env.*
!.env.example
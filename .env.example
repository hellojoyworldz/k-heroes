# =========================================================================
# BACKEND SYSTEM CONFIG
# =========================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
# 쉼표(,)로 구분하여 등록.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =========================================================================
# FRONTEND CONFIG (Next.js 브라우저 노출용)
# =========================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# =========================================================================
# THIRD-PARTY API KEYS
# =========================================================================
OPENAI_API_KEY=your_openai_api_key_here

# =========================================================================
# DATABASE / VECTOR STORE
# =========================================================================
# SQLite (로컬 백업용)
# DATABASE_URL=sqlite:///db/k_heroes.db

# Supabase (PostgreSQL) 직접 연결 (실서버 배포 / IPv6 호환 환경용)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# Supabase (PostgreSQL) 로컬 터널 연결 (로컬 Docker IPv6 미지원 해결용)
DATABASE_URL=postgresql://postgres:[PASSWORD]@host.docker.internal:5433/postgres

SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# =========================================================================
# GCP CONFIG
# =========================================================================
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_BUCKET_NAME=your_gcp_bucket_name_here

# =========================================================================
# GOOGLE AUTH
# =========================================================================
GOOGLE_CLIENT_ID=your_google_client_id_here

# =========================================================================
# ADMIN AUTH (JWT)
# =========================================================================
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=24
ADMIN_COOKIE_SECURE=false # Local HTTP: false / Production HTTPS: true
BOOTSTRAP_ADMIN_USERNAME=superadmin
BOOTSTRAP_ADMIN_PASSWORD=change-me-min-8-chars

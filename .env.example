# =========================================================================
# BACKEND SYSTEM CONFIG
# =========================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Local 
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production 
# NEXT_PUBLIC_API_BASE_URL=https://api.your-backend-domain.com
# CORS_ORIGINS=https://www.k-heroes.co.kr

# =========================================================================
# THIRD-PARTY API KEYS
# =========================================================================
OPENAI_API_KEY=your_openai_api_key_here

# =========================================================================
# DATABASE / VECTOR STORE
# =========================================================================
VECTOR_DB_URL=your_vector_db_url_here

# =========================================================================
# ADMIN AUTH (JWT)
# =========================================================================
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=24
ADMIN_COOKIE_SECURE=false # Local HTTP: false / Production HTTPS: true
BOOTSTRAP_ADMIN_USERNAME=superadmin
BOOTSTRAP_ADMIN_PASSWORD=change-me-min-8-chars
